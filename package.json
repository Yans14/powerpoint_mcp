{
  "name": "powerpoint-mcp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "check": "npm run build && npm test && npm run lint:py && npm run format:check:py && npm run test:py",
    "lint:py": "ruff check python",
    "format:py": "black python",
    "format:check:py": "black --check python",
    "precommit:install": "pre-commit install --install-hooks",
    "precommit:run": "pre-commit run --all-files",
    "test": "vitest run",
    "test:py": "PYTHONPATH=python pytest -q python/tests"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^4.0.18"
  }
}
